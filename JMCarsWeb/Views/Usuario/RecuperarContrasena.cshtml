@{
    ViewData["Title"] = "Recuperar Contrasena";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <h2>Recuperar Contraseña</h2>

        @if(TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        @if(TempData["Mensaje"] != null)
        {
            <div class="alert alert-success">@TempData["Mensaje"]</div>
        }

        @if(ViewBag.Mensaje != null)
        {
            <div class="alert alert-success">@ViewBag.Mensaje</div>
        }

        @if(ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <p class="text-muted">Ingresá tu Email y te enviarémos instrucciones para resetear tu contraseña</p>

        @using (Html.BeginForm("RecuperarContrasena", "Usuario", FormMethod.Post))
        {
            <div class=" mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-primary">Enviar Instrucciones</button>
        }

        <p class="mt-3">
            @Html.ActionLink("Volver al Login", "Index", "Login")
        </p>
    </div>
</div>