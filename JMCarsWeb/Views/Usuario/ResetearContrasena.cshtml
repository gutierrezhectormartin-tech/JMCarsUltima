@{
    ViewData["Title"] = "Restablecer Contraseña";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <h2>Restablecer Contraseña</h2>

        @if(ViewBag.Mensaje != null)
        {
            <div class="alert alert-success">@ViewBag.Mensaje</div>
        }
        @if(ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        @using (Html.BeginForm("ResetearContrasena", "Usuario", FormMethod.Post))
        {
            <input type="hidden" name="ptoken" value="@ViewBag.Token"/>

            <div class="mb-3">
                <label class="form-label">Nueva Contraseña</label>
                <input type="password" name="pNuevaContrasena" class="form-control" required minlength="3" />
            </div>

            <button type="submit" class="btn btn-primary">Restablecer Contraseña</button>
        }
    </div>
</div>
