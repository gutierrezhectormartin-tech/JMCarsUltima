@model Modelo.Escribano
@{
    ViewData["Title"] = "Mi perfil";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <h2>Mi perfil</h2>

        @if (ViewBag.Mensaje != null)
        {
            <div class="alert alert-success">@ViewBag.Mensaje</div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        @using (Html.BeginForm("Perfil", "Escribano", FormMethod.Post))
        {
            <div class="mb-3">
                @Html.LabelFor(m => m.NombreCompleto, "Nombre completo", new { @class = "form-label" })
                @Html.TextBoxFor(m => m.NombreCompleto, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.NombreCompleto, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.Telefono, "Teléfono", new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Telefono, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.Email, "Email", new { @class = "form-label" })
                <p class="form-control-plaintext">@Model.Email</p>
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.NumeroCaja, "Número de caja profesional", new { @class = "form-label" })
                <p class="form-control-plaintext">@Model.NumeroCaja</p>
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.Direccion, "Dirección del estudio", new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Direccion, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Direccion, "", new { @class = "text-danger" })
            </div>
            <button type="submit" class="btn btn-primary">Guardar cambios</button>
        }

        <hr class="my-4" />

        <h5>Inactivar cuenta</h5>
        <p class="text-muted">Si inactivás tu cuenta vas a quedar fuera del sistema. Podés volver a registrarte luego.</p>
        @using (Html.BeginForm("Inactivar", "Escribano", FormMethod.Post))
        {
            <button type="submit" class="btn btn-danger">Inactivar mi cuenta</button>
        }
    </div>
</div>
