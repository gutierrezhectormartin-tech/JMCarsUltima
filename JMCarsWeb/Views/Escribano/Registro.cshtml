@model Modelo.Escribano
@{
    ViewData["Title"] = "Registro de Escribano";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <h2>Registro de Escribano</h2>
        <p class="text-muted">Tu cuenta será activada cuando un administrador la apruebe.</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        @using (Html.BeginForm("Registro", "Escribano", FormMethod.Post))
        {
            <div class="mb-3">
                @Html.LabelFor(m => m.NombreCompleto, "Nombre completo", new { @class = "form-label" })
                @Html.TextBoxFor(m => m.NombreCompleto, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.NombreCompleto, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.Telefono, "Teléfono", new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Telefono, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.Email, "Email", new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email" })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.Contrasena, "Contraseña", new { @class = "form-label" })
                @Html.PasswordFor(m => m.Contrasena, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Contrasena, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.NumeroCaja, "Número de caja profesional", new { @class = "form-label" })
                @Html.TextBoxFor(m => m.NumeroCaja, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.NumeroCaja, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.Direccion, "Dirección del estudio", new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Direccion, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Direccion, "", new { @class = "text-danger" })
            </div>
            <button type="submit" class="btn btn-primary">Registrarme</button>
            @Html.ActionLink("Volver al login", "Index", "Login", null, new { @class = "btn btn-link" })
        }
    </div>
</div>
