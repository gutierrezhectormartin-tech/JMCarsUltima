@using Modelo
@{
    // leo el nombre del usuario logueado desde la sesion (null si no hay sesion)
    var nombreUsuario = Context.Session.GetString("NombreCompleto");
    var idRol = Context.Session.GetInt32("IdRol");
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JMCars</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-dark mb-4">
            <div class="container">
                <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                    <img src="~/images/logo.png" height="80" alt="JMCars" />
                </a>

                <div>
                    @if (string.IsNullOrEmpty(nombreUsuario))
                    {
                        @Html.ActionLink("Iniciar sesión", "Index", "Login", null, new { @class = "btn btn-outline-light" })
                    }
                    else
                    {
                        <span class="text-white me-3">Hola, @nombreUsuario</span>
                        @if (idRol == (int)Rol.Cliente)
                        {
                            @Html.ActionLink("Mi perfil", "Perfil", "Cliente", null, new { @class = "btn btn-outline-light me-2" })
                        }
                        else if (idRol == (int)Rol.Escribano)
                        {
                            @Html.ActionLink("Mi perfil", "Perfil", "Escribano", null, new { @class = "btn btn-outline-light me-2" })
                        }
                        @Html.ActionLink("Cerrar sesión", "Logout", "Login", null, new { @class = "btn btn-outline-light" })
                    }
                </div>
            </div>
        </nav>
    </header>
    <main class="container">
        @RenderBody()
    </main>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
