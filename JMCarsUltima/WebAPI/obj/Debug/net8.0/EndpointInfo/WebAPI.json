  "components": {
    "schemas": {
      "Cliente": {
        "required": [
          "cedula",
          "contrasena",
          "email",
          "nombreCompleto",
          "telefono"
        ],
        "type": "object",
        "properties": {
          "idUsuario": {
            "type": "integer",
            "format": "int32"
          },
          "nombreCompleto": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "telefono": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string"
          },
          "email": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string",
            "format": "email"
          },
          "contrasena": {
            "maxLength": 255,
            "minLength": 3,
            "type": "string"
          },
          "estadoUsu": {
            "type": "boolean"
          },
          "cedula": {
            "minLength": 1,
            "pattern": "^[0-9]{7,8}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "Escribano": {
        "required": [
          "contrasena",
          "direccion",
          "email",
          "nombreCompleto",
          "numeroCaja",
          "telefono"
        ],
        "type": "object",
