            "minLength": 3,
            "type": "string"
          },
          "estadoUsu": {
            "type": "boolean"
          },
          "numeroCaja": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "direccion": {
            "maxLength": 200,
            "minLength": 0,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
